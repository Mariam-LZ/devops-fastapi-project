vrrp_instance VI_1 {

    # The first master starts as the preferred VIP owner.
    # Other masters stay in BACKUP mode and take over if needed.
    state {{ 'MASTER' if inventory_hostname == groups['masters'][0] else 'BACKUP' }}

    # Network interface used for VRRP advertisements and VIP assignment.
    interface {{ keepalived_interface }}

    # VRRP group identifier.
    # Must be identical on all participating nodes.
    virtual_router_id 51

    # Higher priority nodes are preferred as VIP owners.
    # Priority order follows the masters inventory order.
    priority {{ 200 if inventory_hostname == groups['masters'][0] else 150 if inventory_hostname == groups['masters'][1] else 100 }}

    # VRRP advertisement interval in seconds.
    # Lower values allow faster failover detection.
    advert_int 1

    authentication {
        auth_type PASS
        auth_pass {{ keepalived_auth_pass }}
    }

    virtual_ipaddress {

        # Shared virtual IP used as the stable Kubernetes API endpoint.
        # Keepalived automatically moves this VIP between masters during failover.
        {{ kube_api_vip }}/24
    }
}